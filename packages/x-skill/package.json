{
  "name": "@ant-design/x-skill",
  "version": "2.3.0",
  "description": "placeholder for @ant-design/x-sdk",
  "homepage": "https://x.ant.design/x-skills/introduce",
  "bugs": {
    "url": "https://github.com/ant-design/x/issues"
  },
  "bin": {
    "x-skill": "bin/index.js"
  },
  "keywords": [
    "AI",
    "SKILL",
    "Agent",
    "Copilot",
    "ant",
    "sdk",
    "framework",
    "react"
  ],
  "scripts": {
    "precompile": "npm run prestart",
    "compile": "father build",
    "skillApi": "tsx scripts/skillApi.ts",
    "test": "jest --config .jest.js --no-cache --collect-coverage",
    "coverage": "jest --config .jest.js --no-cache --collect-coverage --coverage",
    "test:dekko": "tsx scripts/dekko.ts",
    "prepublishOnly": "tsx ../../scripts/pre-publish.ts x-skill",
    "version": "tsx scripts/generate-version.ts",
    "clean": "rm -rf coverage lib es",
    "pretest": "npm run prestart",
    "start": "ut run compile && node bin/index.js",
    "prestart": "npm run skillApi && npm run version",
    "lint": "biome lint bin/",
    "tsc": "tsc --noEmit"
  },
  "sideEffects": true,
  "files": [
    "skills",
    "skills-zh",
    "bin",
    ".skill.json",
    ".claude-plugin",
    "LICENSE"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ant-design/x"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.5",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.0.3",
    "jest": "^29.7.0",
    "mock-fs": "^5.5.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "figlet": "^1.10.0",
    "ora": "^8.2.0",
    "progress": "^2.0.3"
  }
}